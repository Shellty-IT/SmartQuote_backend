# smartquote_backend/.env.example

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/smartquote"

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
ENCRYPTION_KEY="32-character-encryption-key-here"

# ============================================
# AI INTEGRATION
# ============================================
GEMINI_API_KEY="your-gemini-api-key-from-google-ai-studio"
GEMINI_MODEL="gemini-2.5-flash"

# ============================================
# APPLICATION
# ============================================
NODE_ENV="development"
PORT="5000"
FRONTEND_URL="http://localhost:3000"

# ============================================
# EMAIL (OPTIONAL)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="SmartQuote AI <noreply@smartquote.ai>"

# ============================================
# EXTERNAL INTEGRATIONS (OPTIONAL)
# ============================================
KSEF_MASTER_URL="http://localhost:5000"
KSEF_MASTER_API_KEY="sk_smartquote_ksef_bridge_secret"

# ============================================
# CRON JOBS (OPTIONAL)
# ============================================
CRON_SECRET="your-cron-secret-for-authentication"