// smartquote_backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  avatar    String?
  role      UserRole @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients        Client[]
  offers         Offer[]
  followUps      FollowUp[]
  contracts      Contract[]
  settings       UserSettings?
  companyInfo    CompanyInfo?
  apiKeys        ApiKey[]
  notifications  Notification[]
  legacyInsights OfferLegacyInsight[]

  @@map("users")
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme    String @default("light")
  language String @default("pl")

  emailNotifications Boolean @default(true)
  offerNotifications Boolean @default(true)
  followUpReminders  Boolean @default(true)
  weeklyReport       Boolean @default(true)

  aiTone            String  @default("professional")
  aiAutoSuggestions Boolean @default(true)

  smtpHost       String?
  smtpPort       Int?      @default(587)
  smtpUser       String?
  smtpPass       String?
  smtpFrom       String?
  smtpConfigured Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

model CompanyInfo {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String?
  nip         String?
  regon       String?
  address     String?
  city        String?
  postalCode  String?
  country     String? @default("Polska")
  phone       String?
  email       String?
  website     String?
  bankName    String?
  bankAccount String?
  logo        String?

  defaultPaymentDays Int     @default(14)
  defaultTerms       String?
  defaultNotes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_info")
}

model ApiKey {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  key         String    @unique
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  permissions String[]  @default(["read"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([key])
  @@map("api_keys")
}

model Client {
  id         String     @id @default(cuid())
  type       ClientType @default(COMPANY)
  name       String
  email      String?
  phone      String?
  company    String?
  nip        String?
  regon      String?
  address    String?
  city       String?
  postalCode String?
  country    String?    @default("Polska")
  website    String?
  notes      String?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers    Offer[]
  followUps FollowUp[]
  contracts Contract[]

  @@index([userId])
  @@index([userId, name])
  @@index([name])
  @@index([email])
  @@map("clients")
}

model Offer {
  id          String      @id @default(cuid())
  number      String
  title       String
  description String?
  status      OfferStatus @default(DRAFT)

  totalNet   Decimal @default(0) @db.Decimal(12, 2)
  totalVat   Decimal @default(0) @db.Decimal(12, 2)
  totalGross Decimal @default(0) @db.Decimal(12, 2)
  currency   String  @default("PLN")

  validUntil DateTime?
  sentAt     DateTime?
  viewedAt   DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?

  notes       String?
  terms       String?
  paymentDays Int     @default(14)

  publicToken        String?  @unique
  isInteractive      Boolean  @default(false)
  viewCount          Int      @default(0)
  lastViewedAt       DateTime?
  clientSelectedData Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items        OfferItem[]
  followUps    FollowUp[]
  contracts    Contract[]
  views        OfferView[]
  interactions OfferInteraction[]
  comments     OfferComment[]
  legacyInsights OfferLegacyInsight[]

  @@unique([userId, number])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([publicToken])
  @@map("offers")
}

model OfferItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unit        String   @default("szt.")
  unitPrice   Decimal  @db.Decimal(12, 2)
  vatRate     Decimal  @default(23) @db.Decimal(5, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  totalNet    Decimal  @db.Decimal(12, 2)
  totalVat    Decimal  @db.Decimal(12, 2)
  totalGross  Decimal  @db.Decimal(12, 2)
  position    Int      @default(0)

  isOptional  Boolean  @default(false)
  isSelected  Boolean  @default(true)
  minQuantity Int      @default(1)
  maxQuantity Int      @default(100)

  variantName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@index([offerId, name])
  @@index([offerId, variantName])
  @@index([name])
  @@map("offer_items")
}

model OfferView {
  id        String   @id @default(cuid())
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())
  ipAddress String?
  userAgent String?
  duration  Int?

  @@index([offerId])
  @@index([offerId, viewedAt])
  @@map("offer_views")
}

model OfferInteraction {
  id        String          @id @default(cuid())
  offerId   String
  offer     Offer           @relation(fields: [offerId], references: [id], onDelete: Cascade)
  type      InteractionType
  details   Json?
  createdAt DateTime        @default(now())

  @@index([offerId])
  @@index([offerId, type])
  @@index([offerId, createdAt])
  @@map("offer_interactions")
}

model OfferComment {
  id        String        @id @default(cuid())
  offerId   String
  offer     Offer         @relation(fields: [offerId], references: [id], onDelete: Cascade)
  author    CommentAuthor
  content   String
  createdAt DateTime      @default(now())

  @@index([offerId])
  @@index([offerId, createdAt])
  @@map("offer_comments")
}

model OfferLegacyInsight {
  id        String   @id @default(cuid())
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  outcome   String
  insights  Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([offerId])
  @@map("offer_legacy_insights")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("notifications")
}

model Contract {
  id          String         @id @default(cuid())
  number      String
  title       String
  description String?
  status      ContractStatus @default(DRAFT)

  totalNet   Decimal @default(0) @db.Decimal(12, 2)
  totalVat   Decimal @default(0) @db.Decimal(12, 2)
  totalGross Decimal @default(0) @db.Decimal(12, 2)
  currency   String  @default("PLN")

  startDate DateTime?
  endDate   DateTime?
  signedAt  DateTime?

  terms        String?
  paymentTerms String?
  paymentDays  Int     @default(14)

  notes String?

  publicToken  String?  @unique
  sentAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  offerId   String?
  offer     Offer?         @relation(fields: [offerId], references: [id], onDelete: SetNull)
  items     ContractItem[]
  followUps FollowUp[]

  @@unique([userId, number])
  @@index([userId])
  @@index([userId, status])
  @@index([clientId])
  @@index([offerId])
  @@index([status])
  @@index([createdAt])
  @@index([publicToken])
  @@map("contracts")
}

model ContractItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unit        String   @default("szt.")
  unitPrice   Decimal  @db.Decimal(12, 2)
  vatRate     Decimal  @default(23) @db.Decimal(5, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  totalNet    Decimal  @db.Decimal(12, 2)
  totalVat    Decimal  @db.Decimal(12, 2)
  totalGross  Decimal  @db.Decimal(12, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_items")
}

model FollowUp {
  id          String         @id @default(cuid())
  title       String
  description String?
  type        FollowUpType
  status      FollowUpStatus @default(PENDING)
  priority    Priority       @default(MEDIUM)
  dueDate     DateTime
  completedAt DateTime?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  offerId    String?
  offer      Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([clientId])
  @@index([offerId])
  @@index([contractId])
  @@index([dueDate])
  @@index([status])
  @@index([priority])
  @@map("follow_ups")
}

enum UserRole {
  USER
  ADMIN
}

enum ClientType {
  PERSON
  COMPANY
}

enum OfferStatus {
  DRAFT
  SENT
  VIEWED
  NEGOTIATION
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  COMPLETED
  TERMINATED
  EXPIRED
}

enum FollowUpType {
  CALL
  EMAIL
  MEETING
  TASK
  REMINDER
  OTHER
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  CANCELLED
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InteractionType {
  VIEW
  ITEM_SELECT
  ITEM_DESELECT
  QUANTITY_CHANGE
  ACCEPT
  REJECT
  COMMENT
  PDF_DOWNLOAD
  VARIANT_SWITCH
}

enum CommentAuthor {
  CLIENT
  SELLER
}

enum NotificationType {
  OFFER_VIEWED
  OFFER_ACCEPTED
  OFFER_REJECTED
  OFFER_COMMENT
  AI_INSIGHT
  FOLLOW_UP_REMINDER
  SYSTEM
}