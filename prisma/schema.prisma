// smartquote_backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER - Użytkownik systemu
// ============================================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  avatar    String?
  role      UserRole @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacje
  clients     Client[]
  offers      Offer[]
  followUps   FollowUp[]
  contracts   Contract[]
  settings    UserSettings?
  companyInfo CompanyInfo?
  apiKeys     ApiKey[]

  @@map("users")
}

// ============================================
// USER_SETTINGS - Ustawienia użytkownika
// ============================================
model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Wygląd
  theme    String @default("light")
  language String @default("pl")

  // Powiadomienia
  emailNotifications Boolean @default(true)
  offerNotifications Boolean @default(true)
  followUpReminders  Boolean @default(true)
  weeklyReport       Boolean @default(true)

  // AI
  aiTone            String  @default("professional")
  aiAutoSuggestions Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

// ============================================
// COMPANY_INFO - Dane firmy użytkownika
// ============================================
model CompanyInfo {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String?
  nip         String?
  regon       String?
  address     String?
  city        String?
  postalCode  String?
  country     String? @default("Polska")
  phone       String?
  email       String?
  website     String?
  bankName    String?
  bankAccount String?
  logo        String?

  defaultPaymentDays Int     @default(14)
  defaultTerms       String?
  defaultNotes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_info")
}

// ============================================
// API_KEY - Klucze API użytkownika
// ============================================
model ApiKey {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  key         String    @unique
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  permissions String[]  @default(["read"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([key])
  @@map("api_keys")
}

// ============================================
// CLIENT - Klient/Kontrahent
// ============================================
model Client {
  id         String     @id @default(cuid())
  type       ClientType @default(COMPANY)
  name       String
  email      String?
  phone      String?
  company    String?
  nip        String?
  regon      String?
  address    String?
  city       String?
  postalCode String?
  country    String?    @default("Polska")
  website    String?
  notes      String?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers    Offer[]
  followUps FollowUp[]
  contracts Contract[]

  @@index([userId])
  @@index([name])
  @@index([email])
  @@map("clients")
}

// ============================================
// OFFER - Oferta handlowa
// ============================================
model Offer {
  id          String      @id @default(cuid())
  number      String
  title       String
  description String?
  status      OfferStatus @default(DRAFT)

  totalNet   Decimal @default(0) @db.Decimal(12, 2)
  totalVat   Decimal @default(0) @db.Decimal(12, 2)
  totalGross Decimal @default(0) @db.Decimal(12, 2)
  currency   String  @default("PLN")

  validUntil DateTime?
  sentAt     DateTime?
  viewedAt   DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?

  notes       String?
  terms       String?
  paymentDays Int     @default(14)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items     OfferItem[]
  followUps FollowUp[]
  contracts Contract[]

  @@unique([userId, number])
  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("offers")
}

// ============================================
// OFFER_ITEM - Pozycja w ofercie
// ============================================
model OfferItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unit        String   @default("szt.")
  unitPrice   Decimal  @db.Decimal(12, 2)
  vatRate     Decimal  @default(23) @db.Decimal(5, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  totalNet    Decimal  @db.Decimal(12, 2)
  totalVat    Decimal  @db.Decimal(12, 2)
  totalGross  Decimal  @db.Decimal(12, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@map("offer_items")
}

// ============================================
// CONTRACT - Umowa
// ============================================
model Contract {
  id          String         @id @default(cuid())
  number      String
  title       String
  description String?
  status      ContractStatus @default(DRAFT)

  totalNet   Decimal @default(0) @db.Decimal(12, 2)
  totalVat   Decimal @default(0) @db.Decimal(12, 2)
  totalGross Decimal @default(0) @db.Decimal(12, 2)
  currency   String  @default("PLN")

  startDate DateTime?
  endDate   DateTime?
  signedAt  DateTime?

  terms        String?
  paymentTerms String?
  paymentDays  Int     @default(14)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  offerId   String?
  offer     Offer?         @relation(fields: [offerId], references: [id], onDelete: SetNull)
  items     ContractItem[]
  followUps FollowUp[]

  @@unique([userId, number])
  @@index([userId])
  @@index([clientId])
  @@index([offerId])
  @@index([status])
  @@index([createdAt])
  @@map("contracts")
}

// ============================================
// CONTRACT_ITEM - Pozycja w umowie
// ============================================
model ContractItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unit        String   @default("szt.")
  unitPrice   Decimal  @db.Decimal(12, 2)
  vatRate     Decimal  @default(23) @db.Decimal(5, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  totalNet    Decimal  @db.Decimal(12, 2)
  totalVat    Decimal  @db.Decimal(12, 2)
  totalGross  Decimal  @db.Decimal(12, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_items")
}

// ============================================
// FOLLOW_UP - Przypomnienia i zadania
// ============================================
model FollowUp {
  id          String         @id @default(cuid())
  title       String
  description String?
  type        FollowUpType
  status      FollowUpStatus @default(PENDING)
  priority    Priority       @default(MEDIUM)
  dueDate     DateTime
  completedAt DateTime?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  offerId    String?
  offer      Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
  @@index([offerId])
  @@index([contractId])
  @@index([dueDate])
  @@index([status])
  @@index([priority])
  @@map("follow_ups")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  USER
  ADMIN
}

enum ClientType {
  PERSON
  COMPANY
}

enum OfferStatus {
  DRAFT
  SENT
  VIEWED
  NEGOTIATION
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  COMPLETED
  TERMINATED
  EXPIRED
}

enum FollowUpType {
  CALL
  EMAIL
  MEETING
  TASK
  REMINDER
  OTHER
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  CANCELLED
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}