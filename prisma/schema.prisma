// smartquote_backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER - Użytkownik systemu
// ============================================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  company   String?
  phone     String?
  role      UserRole @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacje
  clients   Client[]
  offers    Offer[]
  followUps FollowUp[]
  contracts Contract[]

  @@map("users")
}

// ============================================
// CLIENT - Klient/Kontrahent
// ============================================
model Client {
  id         String     @id @default(cuid())
  type       ClientType @default(COMPANY)
  name       String
  email      String?
  phone      String?
  company    String?
  nip        String?
  regon      String?
  address    String?
  city       String?
  postalCode String?
  country    String?    @default("Polska")
  website    String?
  notes      String?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relacje
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers    Offer[]
  followUps FollowUp[]
  contracts Contract[]

  @@index([userId])
  @@index([name])
  @@index([email])
  @@map("clients")
}

// ============================================
// OFFER - Oferta handlowa
// ============================================
model Offer {
  id          String      @id @default(cuid())
  number      String      // np. "OFF/2024/001"
  title       String
  description String?
  status      OfferStatus @default(DRAFT)

  // Kwoty
  totalNet   Decimal @default(0) @db.Decimal(12, 2)
  totalVat   Decimal @default(0) @db.Decimal(12, 2)
  totalGross Decimal @default(0) @db.Decimal(12, 2)
  currency   String  @default("PLN")

  // Daty
  validUntil DateTime?
  sentAt     DateTime?
  viewedAt   DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?

  // Dodatkowe
  notes       String? // Notatki wewnętrzne
  terms       String? // Warunki płatności
  paymentDays Int     @default(14)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacje
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items     OfferItem[]
  followUps FollowUp[]
  contracts Contract[]

  @@unique([userId, number])
  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("offers")
}

// ============================================
// OFFER_ITEM - Pozycja w ofercie
// ============================================
model OfferItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unit        String   @default("szt.")
  unitPrice   Decimal  @db.Decimal(12, 2)
  vatRate     Decimal  @default(23) @db.Decimal(5, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2) // % rabatu
  totalNet    Decimal  @db.Decimal(12, 2)
  totalVat    Decimal  @db.Decimal(12, 2)
  totalGross  Decimal  @db.Decimal(12, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacje
  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@map("offer_items")
}

// ============================================
// CONTRACT - Umowa
// ============================================
model Contract {
  id          String         @id @default(cuid())
  number      String         // np. "UMW/2024/001"
  title       String
  description String?
  status      ContractStatus @default(DRAFT)

  // Kwoty
  totalNet   Decimal @default(0) @db.Decimal(12, 2)
  totalVat   Decimal @default(0) @db.Decimal(12, 2)
  totalGross Decimal @default(0) @db.Decimal(12, 2)
  currency   String  @default("PLN")

  // Daty
  startDate DateTime? // Data rozpoczęcia umowy
  endDate   DateTime? // Data zakończenia umowy
  signedAt  DateTime? // Data podpisania

  // Warunki
  terms        String? // Warunki umowy
  paymentTerms String? // Warunki płatności
  paymentDays  Int     @default(14)

  // Dodatkowe
  notes String? // Notatki wewnętrzne

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacje
  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  client   Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  offerId  String?        // Opcjonalne - umowa może powstać z oferty
  offer    Offer?         @relation(fields: [offerId], references: [id], onDelete: SetNull)
  items    ContractItem[]

  @@unique([userId, number])
  @@index([userId])
  @@index([clientId])
  @@index([offerId])
  @@index([status])
  @@index([createdAt])
  @@map("contracts")
}

// ============================================
// CONTRACT_ITEM - Pozycja w umowie
// ============================================
model ContractItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unit        String   @default("szt.")
  unitPrice   Decimal  @db.Decimal(12, 2)
  vatRate     Decimal  @default(23) @db.Decimal(5, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2) // % rabatu
  totalNet    Decimal  @db.Decimal(12, 2)
  totalVat    Decimal  @db.Decimal(12, 2)
  totalGross  Decimal  @db.Decimal(12, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacje
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_items")
}

// ============================================
// FOLLOW_UP - Przypomnienia i zadania
// ============================================
model FollowUp {
  id          String         @id @default(cuid())
  title       String
  description String?
  type        FollowUpType
  status      FollowUpStatus @default(PENDING)
  priority    Priority       @default(MEDIUM)
  dueDate     DateTime
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relacje
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  offerId  String?
  offer    Offer?  @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dueDate])
  @@index([status])
  @@map("follow_ups")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  USER
  ADMIN
}

enum ClientType {
  PERSON  // Osoba fizyczna
  COMPANY // Firma
}

enum OfferStatus {
  DRAFT       // Szkic
  SENT        // Wysłana
  VIEWED      // Obejrzana
  NEGOTIATION // Negocjacje
  ACCEPTED    // Zaakceptowana
  REJECTED    // Odrzucona
  EXPIRED     // Wygasła
}

enum ContractStatus {
  DRAFT             // Szkic
  PENDING_SIGNATURE // Oczekuje na podpis
  ACTIVE            // Aktywna
  COMPLETED         // Zakończona
  TERMINATED        // Rozwiązana
  EXPIRED           // Wygasła
}

enum FollowUpType {
  CALL     // Telefon
  EMAIL    // Email
  MEETING  // Spotkanie
  REMINDER // Przypomnienie
  OTHER    // Inne
}

enum FollowUpStatus {
  PENDING   // Oczekujący
  COMPLETED // Wykonany
  CANCELLED // Anulowany
  OVERDUE   // Przeterminowany
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}